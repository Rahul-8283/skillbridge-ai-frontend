# SkillBridge AI Frontend Environment Variables
# Copy this file to .env and update with your actual values

# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
VITE_APP_MODE=development

# ============================================
# BACKEND URLS
# ============================================
# Development: Local Node.js backend
VITE_BACKEND_URL_DEV=http://localhost:5000

# Production: Your deployed backend URL
VITE_BACKEND_URL_PROD=https://api.skillbridge.com

# ============================================
# AUTH0 CONFIGURATION
# ============================================
# Get these from your Auth0 application settings
VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_client_id_here
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/callback

# ============================================
# FASTAPI BACKEND (Optional Direct Integration)
# ============================================
VITE_FASTAPI_URL=http://localhost:8000

# ============================================
# APP CONFIGURATION
# ============================================
VITE_APP_NAME=SkillBridge AI
VITE_APP_VERSION=1.0.0

# ============================================
# FEATURE FLAGS
# ============================================
# Set to false to use mock data instead of API
VITE_ENABLE_MOCK_DATA=true

# Enable RAG system integration
VITE_ENABLE_RAG=true

# Enable skill extraction features
VITE_ENABLE_SKILL_EXTRACTION=true
